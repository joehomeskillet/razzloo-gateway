# Caddy reverse proxy for the Razzoozle rendezvous gateway.
# Caddy terminates TLS (automatic ACME), sets security headers, and proxies to
# the Node/Fastify service on 127.0.0.1:8787. The gateway never serves binaries.
#
# Copy to /etc/caddy/Caddyfile (or import it) and `systemctl reload caddy`.

gw.razzoozle.xyz {
	encode zstd gzip

	# Security headers (threat-model §11). HSTS is added by Caddy on https sites.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		# Tight CSP for the only HTML we serve (the /j/:code join page). The page
		# uses one inline <script> and same-origin <img> (the QR); no external
		# origins, no eval. 'unsafe-inline' is required for the inline bootstrap
		# script; it loads no third-party code.
		Content-Security-Policy "default-src 'none'; script-src 'unsafe-inline'; img-src 'self' data:; style-src 'unsafe-inline'; connect-src 'self'; base-uri 'none'; form-action 'none'"
		-Server
	}

	# Front-line connection limit (the app also rate-limits per route + locks out
	# join brute-force). Caddy's built-in is intentionally coarse.
	reverse_proxy 127.0.0.1:8787 {
		header_up X-Forwarded-For {remote_host}
		header_up X-Real-IP {remote_host}
	}

	log {
		output file /var/log/caddy/gw.razzoozle.xyz.log
		# Do NOT log request bodies; Caddy access logs are URL-only by default.
	}
}
